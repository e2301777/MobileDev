<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:id="@+id/main"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/calcDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:layout_marginEnd="10dp"
        android:gravity="end"
        android:hint="@string/displayHint"
        android:textSize="36sp" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*">

        <TableRow>
            <Button
                android:text="@string/clear"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onClearClick"/>
            <Button
                android:text="@string/percent"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onOperatorClick"/>
            <Button
                android:text="@string/backspace"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onBackSpaceClick"/>
            <Button
                android:text="@string/divide"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onOperatorClick"/>
        </TableRow>

        <TableRow>
            <Button
                android:text="@string/num7"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/num8"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/num9"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/multiply"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onOperatorClick"/>
        </TableRow>

        <TableRow>
            <Button
                android:text="@string/num4"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/num5"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/num6"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/subtract"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onOperatorClick"/>
        </TableRow>

        <TableRow>
            <Button
                android:text="@string/num1"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/num2"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/num3"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/add"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onOperatorClick"/>
        </TableRow>

        <TableRow>
            <Button
                android:text="@string/num00"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/num0"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/dot"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onNumberClick"/>
            <Button
                android:text="@string/equals"
                android:textSize="20sp"
                android:layout_marginHorizontal="2dp"
                android:onClick="onEqualClick"/>
        </TableRow>

    </TableLayout>
</LinearLayout>